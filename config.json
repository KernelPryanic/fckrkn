{
  "log": {
    "loglevel": "debug"
  },
  "dns": {
    "servers": [
      "8.8.8.8",
      "8.8.4.4",
      "1.1.1.1",
      "1.0.0.1",
      "9.9.9.9",
      "149.112.112.112",
      "91.239.100.100",
      "89.233.43.71",
      "84.200.69.80",
      "84.200.70.40",
      "80.80.80.80",
      "80.80.81.81"
    ]
  },
  "policy": {
    "levels": {
      "0": {
        "handshake": 4,
        "connIdle": 300,
        "uplinkOnly": 2,
        "downlinkOnly": 5,
        "bufferSize": 10240
      }
    }
  },
  "inbounds": [
    {
      "tag": "vmess-xhttp-tls",
      "port": 8080,
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": "00000000-0000-0000-0000-000000000000",
            "alterId": 0
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "xhttpSettings": {
          "path": "/v1/disk/resources/download",
          "host": "disk.yandex.ru",
          "mode": "auto"
        },
        "tlsSettings": {
          "serverName": "disk.yandex.ru",
          "alpn": ["h2"],
          "certificates": [
            {
              "certificateFile": "/etc/ssl/certs/xray/fullchain.pem",
              "keyFile": "/etc/ssl/certs/xray/privkey.pem"
            }
          ]
        },
        "sockopt": {
          "tcpFastOpen": true,
          "tcpKeepAliveInterval": 30
        }
      }
    },
    {
      "tag": "vless-reality",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "11111111-1111-1111-1111-111111111111",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "ya.ru:443",
          "serverNames": ["ya.ru", "yandex.ru"],
          "privateKey": "YOUR_REALITY_PRIVATE_KEY",
          "shortIds": ["YOUR_SHORT_ID"]
        },
        "sockopt": {
          "tcpFastOpen": true,
          "tcpKeepAliveInterval": 30
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    },
    {
      "tag": "vless-mkcp",
      "port": 51820,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "11111111-1111-1111-1111-111111111111"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "kcp",
        "kcpSettings": {
          "mtu": 1350,
          "tti": 20,
          "uplinkCapacity": 50,
          "downlinkCapacity": 100,
          "congestion": false,
          "readBufferSize": 2,
          "writeBufferSize": 2,
          "header": {
            "type": "wechat-video"
          },
          "seed": "YOUR_KCP_SEED"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    },
    {
      "tag": "trojan-xhttp-tls",
      "port": 8880,
      "protocol": "trojan",
      "settings": {
        "clients": [
          {
            "password": "YOUR_TROJAN_PASSWORD"
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "xhttpSettings": {
          "path": "/trojan-xh",
          "mode": "auto"
        },
        "tlsSettings": {
          "alpn": ["h2"],
          "certificates": [
            {
              "certificateFile": "/etc/ssl/certs/xray/fullchain.pem",
              "keyFile": "/etc/ssl/certs/xray/privkey.pem"
            }
          ]
        },
        "sockopt": {
          "tcpFastOpen": true,
          "tcpKeepAliveInterval": 30
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      },
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "settings": {},
      "tag": "blocked"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "ip": ["geoip:private"],
        "outboundTag": "blocked"
      }
    ]
  }
}

